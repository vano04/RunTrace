{
  "mcpServers": {
    "runtrace": {
      "title": "RunTrace",
      "description": "Retrieve prior experiment evidence and record agent research runs.",
      "command": "uvx",
      "args": [
        "--from",
        "runtrace[mcp] @ git+https://github.com/vano04/RunTrace.git@v0.1.0",
        "runtrace-mcp"
      ],
      "env_vars": ["RUNTRACE_BASE_URL", "RUNTRACE_API_TOKEN"]
    }
  }
}
