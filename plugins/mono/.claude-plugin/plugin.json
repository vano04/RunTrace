{
  "name": "mono",
  "version": "0.1.6",
  "description": "Persistent experiment memory and run tracking for autonomous research agents.",
  "author": {
    "name": "Mono contributors"
  },
  "homepage": "https://github.com/vano04/Mono",
  "repository": "https://github.com/vano04/Mono",
  "mcpServers": {
    "mono": {
      "command": "uvx",
      "args": [
        "--from",
        "mono-research[mcp]==0.1.6",
        "mono-mcp"
      ],
      "env": {
        "MONO_BASE_URL": "${MONO_BASE_URL:-http://localhost:8000}",
        "MONO_API_TOKEN": "${MONO_API_TOKEN}"
      }
    }
  }
}
